# Configuração do banco de dados.
# Local (padrão): SQLite num arquivo na pasta backend.
DATABASE_URL=sqlite:///./gado.db

# Para subir na nuvem (Supabase), troque por algo como:
# DATABASE_URL=postgresql+psycopg://usuario:senha@host:5432/postgres

# Segredo que assina o login. Em produção (Render), gere um valor aleatório
# único e nunca reaproveite o padrão do código.
AUTH_SECRET=troque-este-segredo-em-producao-gado-agua-do-tigre

# Quantos dias o login fica válido no celular sem precisar entrar de novo.
TOKEN_DIAS=60
